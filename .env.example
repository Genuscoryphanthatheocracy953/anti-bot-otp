NODE_ENV=development
PORT=3000
HOST=0.0.0.0

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=otppoc
POSTGRES_USER=otppoc
POSTGRES_PASSWORD=otppoc_secret_change_me

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long_abc123
PREFLIGHT_SECRET=change_me_preflight_secret_at_least_32_chars_long
REFRESH_TOKEN_SECRET=change_me_refresh_token_secret_at_least_32_chars
ATTESTATION_SECRET=change_me_attestation_secret_32_chars_long_abc
HMAC_CLIENT_KEY=change_me_hmac_client_key_at_least_32_chars_long

# Telegram OTP Delivery (see README.md "Telegram Bot Setup" section)
# Leave empty to use DEV_MODE=true (OTP logged to console instead)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DEV_MODE=true

OTP_TTL_SECONDS=180
OTP_LENGTH=6
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5

PREFLIGHT_TTL_SECONDS=120
POW_DIFFICULTY=4

# Local dev overrides (uncomment for non-Docker setup)
# POSTGRES_HOST=localhost
# REDIS_HOST=localhost
